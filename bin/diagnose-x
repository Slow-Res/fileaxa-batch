#!/usr/bin/env bash
# Print a snapshot of what's using your X11 connection slots.
# Helpful when bin/start fails with "Maximum number of clients reached".
set -euo pipefail

DISP=${DISPLAY:-:0}

echo "=== X server: $DISP ==="
if command -v xdpyinfo >/dev/null 2>&1; then
    xdpyinfo -display "$DISP" 2>/dev/null | head -5
fi
echo

if command -v xlsclients >/dev/null 2>&1; then
    n_windowed=$(xlsclients -a -display "$DISP" 2>/dev/null | wc -l || echo "?")
    echo "Windowed X clients (with top-level windows): $n_windowed"
    echo "(This is a LOWER bound — many connections have no window.)"
    echo
fi

echo "=== Chrome / Chromium-family processes for $USER ==="
# Each subprocess that talks to X counts as a separate X client.
chrome_total=$(pgrep -u "$USER" -fc "chrome|chromium" 2>/dev/null || echo 0)
chrome_google=$(pgrep -u "$USER" -fc "/opt/google/chrome" 2>/dev/null || echo 0)
chrome_playwright=$(pgrep -u "$USER" -fc "playwright_chromiumdev_profile" 2>/dev/null || echo 0)
echo "  Total chrome/chromium processes:       $chrome_total"
echo "  Of which regular Google Chrome:        $chrome_google"
echo "  Of which Playwright (fileaxa-batch):   $chrome_playwright"
echo

echo "=== Top 10 X-using processes (by FD count to /tmp/.X11-unix) ==="
# Each open FD to the X socket is one connection.
sock_glob="/tmp/.X11-unix/*"
declare -A by_proc
shopt -s nullglob
for sock in $sock_glob; do
    inode=$(stat -c '%i' "$sock" 2>/dev/null || echo "")
    [[ -n "$inode" ]] || continue
done
shopt -u nullglob
ss -xp 2>/dev/null | awk '/X11-unix/ && match($0, /"([^"]+)",pid=([0-9]+)/, m) { print m[1] }' \
    | sort | uniq -c | sort -rn | head -10 || true

echo
echo "=== Suggestions if you're hitting the cap ==="
echo "  1) Close some Chrome tabs/extensions (each uses several X clients)."
echo "  2) Restart Chrome:     pkill -f /opt/google/chrome/chrome"
echo "  3) Raise the X11 cap permanently:"
echo "     sudo tee /etc/X11/xorg.conf.d/99-maxclients.conf <<'EOF'"
echo "     Section \"ServerFlags\""
echo "         Option \"MaxClients\" \"2048\""
echo "     EndSection"
echo "     EOF"
echo "     (then log out and back in)"
