#!/usr/bin/env bash
# Print a snapshot of what's using your X11 connection slots.
# Helpful when bin/start fails with "Maximum number of clients reached".
#
# Deliberately NOT using `set -e` — diagnostic scripts should print every
# section they can even when individual probes (xlsclients, pgrep with no
# matches, ss without root) fail. Each command guards its own errors.

DISP=${DISPLAY:-:0}

echo "=== X server: $DISP ==="
if command -v xdpyinfo >/dev/null 2>&1; then
    xdpyinfo -display "$DISP" 2>/dev/null | head -5
fi
echo

if command -v xlsclients >/dev/null 2>&1; then
    # xlsclients itself opens an X connection, so it can fail when the
    # server is at its cap. Stderr's already suppressed; -p forces line-buffered.
    n_windowed=$(xlsclients -display "$DISP" 2>/dev/null | wc -l)
    [[ -z "$n_windowed" ]] && n_windowed="(?)"
    echo "Windowed X clients (with top-level windows): $n_windowed"
    echo "(Lower bound — many connections have no window.)"
    echo
fi

echo "=== Chrome / Chromium-family processes for $USER ==="
chrome_total=$(pgrep -u "$USER" -fc "chrome|chromium" 2>/dev/null)
chrome_google=$(pgrep -u "$USER" -fc "/opt/google/chrome" 2>/dev/null)
chrome_playwright=$(pgrep -u "$USER" -fc "playwright_chromiumdev_profile" 2>/dev/null)
echo "  Total chrome/chromium processes:       ${chrome_total:-0}"
echo "  Of which regular Google Chrome:        ${chrome_google:-0}"
echo "  Of which Playwright (fileaxa-batch):   ${chrome_playwright:-0}"
echo

echo "=== Top 10 processes by open FDs to /tmp/.X11-unix ==="
# Walk /proc/<pid>/fd and look for symlinks pointing into the X socket dir.
# Works without root for processes the user owns; silently skips others.
{
    for fd_dir in /proc/[0-9]*/fd; do
        pid="${fd_dir%/fd}"
        pid="${pid#/proc/}"
        cnt=$(ls -l "$fd_dir" 2>/dev/null | grep -c "/tmp/.X11-unix/")
        [[ "$cnt" -gt 0 ]] || continue
        # Get the command name (truncated, like ps shows it)
        comm=$(tr -d '\0' < "/proc/$pid/comm" 2>/dev/null || echo "?")
        printf "%4d  pid=%-6s  %s\n" "$cnt" "$pid" "$comm"
    done
} | sort -rn | head -10

echo
echo "=== Suggestions if you're hitting the cap ==="
echo "  1) Close some Chrome tabs/extensions (each uses several X clients)."
echo "  2) Restart Chrome:     pkill -f /opt/google/chrome/chrome"
echo "  3) Raise the X11 cap permanently:"
echo "     sudo tee /etc/X11/xorg.conf.d/99-maxclients.conf <<'EOF'"
echo "     Section \"ServerFlags\""
echo "         Option \"MaxClients\" \"2048\""
echo "     EndSection"
echo "     EOF"
echo "     (then log out and back in)"
