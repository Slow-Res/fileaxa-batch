#!/usr/bin/env bash
# Pull the latest fileaxa-batch from GitHub and reinstall into the local .venv.
#
# Run any time the repo on GitHub is ahead of your local copy:
#   bin/update
# Or from anywhere if bin/ is on PATH:
#   fileaxa-batch-update   # (if you symlinked it)
set -euo pipefail

# Resolve symlinks the same way bin/fileaxa-batch does, so this works
# when invoked via a symlink in ~/.local/bin.
SOURCE=${BASH_SOURCE[0]}
while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR=$(cd -P "$(dirname "$SOURCE")" >/dev/null && pwd)
    SOURCE=$(readlink "$SOURCE")
    [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SCRIPT_DIR=$(cd -P "$(dirname "$SOURCE")" >/dev/null && pwd)
PROJECT_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)

c_blue=$'\033[1;34m' ; c_green=$'\033[1;32m' ; c_yellow=$'\033[1;33m' ; c_reset=$'\033[0m'
say()  { printf "%s==>%s %s\n" "$c_blue" "$c_reset" "$*"; }
ok()   { printf "%s✓%s  %s\n"  "$c_green" "$c_reset" "$*"; }
warn() { printf "%s!%s  %s\n"  "$c_yellow" "$c_reset" "$*"; }

cd "$PROJECT_ROOT"

if [[ ! -d .git ]]; then
    warn "$PROJECT_ROOT is not a git checkout — can't pull updates."
    warn "Re-install with: bin/install"
    exit 1
fi

# Refuse to clobber uncommitted work. Better to surface this than to
# silently stash + lose the user's local edits.
if ! git diff --quiet || ! git diff --cached --quiet; then
    warn "You have uncommitted changes in $PROJECT_ROOT — aborting."
    echo "    Either commit them or stash before re-running:"
    echo "      git stash      # save"
    echo "      bin/update     # update"
    echo "      git stash pop  # restore"
    exit 1
fi

before=$(git rev-parse HEAD)

say "Fetching from origin"
git fetch --tags origin

say "Fast-forwarding main"
git pull --ff-only origin main

after=$(git rev-parse HEAD)

if [[ "$before" == "$after" ]]; then
    ok "Already up to date ($after)."
    exit 0
fi
ok "Updated $before → $after"

if [[ ! -x .venv/bin/python ]]; then
    warn "No .venv found — run bin/install first."
    exit 1
fi

# pip install -e is a no-op if nothing in pyproject.toml changed; cheap to
# run unconditionally and the only reliable way to catch dependency bumps.
say "Refreshing Python dependencies"
.venv/bin/pip install --quiet --upgrade pip
.venv/bin/pip install --quiet -e .
ok "Dependencies up to date"

# Show what changed, so the user knows what's new in this pull.
echo
say "Changes since last update:"
git log --oneline "$before..$after"
echo
ok "Done. Restart the app to pick up the new version:"
echo "    fileaxa-batch"
