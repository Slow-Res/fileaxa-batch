#!/usr/bin/env bash
# fileaxa-batch installer.
#
# Idempotent — safe to re-run. Default install location ~/fileaxa-batch;
# override with FILEAXA_DIR=/path or as the first argument.
#
# One-liner:
#   curl -fsSL https://raw.githubusercontent.com/Slow-Res/fileaxa-batch/main/install.sh | bash
#
# Or clone first then run:
#   git clone https://github.com/Slow-Res/fileaxa-batch.git
#   cd fileaxa-batch && ./install.sh
set -euo pipefail

REPO_URL="https://github.com/Slow-Res/fileaxa-batch.git"
INSTALL_DIR="${1:-${FILEAXA_DIR:-$HOME/fileaxa-batch}}"
LINK_DIR="$HOME/.local/bin"

c_blue=$'\033[1;34m' ; c_green=$'\033[1;32m' ; c_yellow=$'\033[1;33m' ; c_reset=$'\033[0m'
say()  { printf "%s==>%s %s\n" "$c_blue" "$c_reset" "$*"; }
ok()   { printf "%s✓%s  %s\n"  "$c_green" "$c_reset" "$*"; }
warn() { printf "%s!%s  %s\n"  "$c_yellow" "$c_reset" "$*"; }

# ---- prerequisites ---------------------------------------------------------

need() { command -v "$1" >/dev/null 2>&1 || { warn "missing: $1"; return 1; }; }

say "Checking prerequisites"
missing=()
need git    || missing+=(git)
need python3 || missing+=(python3)
if ! python3 -c "import venv" 2>/dev/null; then missing+=(python3-venv); fi

if (( ${#missing[@]} )); then
    warn "Install these first, then re-run:"
    if command -v apt-get >/dev/null 2>&1; then
        echo "    sudo apt install -y ${missing[*]} libxcb-cursor0"
    elif command -v dnf >/dev/null 2>&1; then
        echo "    sudo dnf install -y ${missing[*]} libxcb-cursor"
    elif command -v brew >/dev/null 2>&1; then
        echo "    brew install ${missing[*]}"
    else
        echo "    (use your package manager to install: ${missing[*]})"
    fi
    exit 1
fi
ok "git, python3, python3-venv present"

# PyQt6 needs libxcb-cursor on Debian/Ubuntu — best-effort warning.
if command -v apt-get >/dev/null 2>&1 && ! dpkg -s libxcb-cursor0 >/dev/null 2>&1; then
    warn "libxcb-cursor0 not installed — PyQt6 may fail to start the GUI."
    warn "    Run: sudo apt install -y libxcb-cursor0"
fi

# ---- clone / pull ----------------------------------------------------------

if [[ -d "$INSTALL_DIR/.git" ]]; then
    say "Updating existing clone in $INSTALL_DIR"
    git -C "$INSTALL_DIR" pull --ff-only origin main
else
    say "Cloning into $INSTALL_DIR"
    git clone "$REPO_URL" "$INSTALL_DIR"
fi
ok "Repo at $INSTALL_DIR"

cd "$INSTALL_DIR"

# ---- venv + install --------------------------------------------------------

if [[ ! -x .venv/bin/python ]]; then
    say "Creating virtualenv (.venv)"
    python3 -m venv .venv
fi
ok "venv ready"

say "Installing fileaxa-batch + Python deps"
.venv/bin/pip install --quiet --upgrade pip
.venv/bin/pip install --quiet -e .
ok "Python package installed"

# Playwright Chromium download is ~140MB. Skip if browser already present.
if .venv/bin/python -c "from playwright.sync_api import sync_playwright; import sys; \
sys.exit(0 if sync_playwright().__enter__().chromium.executable_path else 1)" 2>/dev/null; then
    ok "Playwright Chromium already installed"
else
    say "Installing Playwright Chromium (~140MB, one-time)"
    .venv/bin/playwright install chromium
    ok "Chromium installed"
fi

# ---- symlink launcher ------------------------------------------------------

mkdir -p "$LINK_DIR"
ln -sfn "$INSTALL_DIR/bin/fileaxa-batch" "$LINK_DIR/fileaxa-batch"
ok "Linked $LINK_DIR/fileaxa-batch → $INSTALL_DIR/bin/fileaxa-batch"

case ":$PATH:" in
    *":$LINK_DIR:"*) ;;
    *) warn "$LINK_DIR is not on your PATH. Add to ~/.bashrc:"
       echo "       export PATH=\"\$HOME/.local/bin:\$PATH\"" ;;
esac

# ---- done ------------------------------------------------------------------

echo
ok "Setup complete. Launch with:"
echo "    fileaxa-batch"
echo
echo "To upgrade later:"
echo "    $INSTALL_DIR/bin/update"
