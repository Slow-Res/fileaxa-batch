#!/usr/bin/env bash
# Build a self-contained onedir bundle of fileaxa-batch — Python, PyQt6,
# Playwright, AND the Chromium browser are all included. The result runs
# without Python, pip, or any system venv.
#
# Output: dist/fileaxa-batch/  (~300-400 MB depending on Chromium version)
# Run with: dist/fileaxa-batch/fileaxa-batch
#
# Re-run any time you want a fresh build; it removes the old one first.
set -euo pipefail

# ---- locate project root ---------------------------------------------------
SOURCE=${BASH_SOURCE[0]}
while [[ -L "$SOURCE" ]]; do
    SOURCE_DIR=$(cd -P "$(dirname "$SOURCE")" >/dev/null && pwd)
    SOURCE=$(readlink "$SOURCE")
    [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SCRIPT_DIR=$(cd -P "$(dirname "$SOURCE")" >/dev/null && pwd)
PROJECT_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)

c_blue=$'\033[1;34m' ; c_green=$'\033[1;32m' ; c_yellow=$'\033[1;33m' ; c_reset=$'\033[0m'
say()  { printf "%s==>%s %s\n" "$c_blue"   "$c_reset" "$*"; }
ok()   { printf "%s✓%s  %s\n"  "$c_green"  "$c_reset" "$*"; }
warn() { printf "%s!%s  %s\n"  "$c_yellow" "$c_reset" "$*"; }

cd "$PROJECT_ROOT"

VENV_PY="$PROJECT_ROOT/.venv/bin/python"
if [[ ! -x "$VENV_PY" ]]; then
    warn "No .venv found. Run bin/install first."
    exit 1
fi

# ---- pyinstaller -----------------------------------------------------------

if ! "$VENV_PY" -m PyInstaller --version >/dev/null 2>&1; then
    say "Installing PyInstaller into .venv"
    "$VENV_PY" -m pip install --quiet pyinstaller
fi
ok "PyInstaller present"

# ---- clean previous build --------------------------------------------------

BUNDLE_DIR="$PROJECT_ROOT/dist/fileaxa-batch"
BUILD_DIR="$PROJECT_ROOT/build"
SPEC_FILE="$PROJECT_ROOT/fileaxa-batch.spec"

if [[ -d "$BUNDLE_DIR" ]]; then
    say "Removing previous bundle at $BUNDLE_DIR"
    rm -rf "$BUNDLE_DIR"
fi
rm -rf "$BUILD_DIR" "$SPEC_FILE"

# ---- build -----------------------------------------------------------------

say "Running PyInstaller (onedir)"
"$VENV_PY" -m PyInstaller \
    --noconfirm \
    --onedir \
    --windowed \
    --name fileaxa-batch \
    --paths src \
    --add-data "src/fileaxa_batch/data:fileaxa_batch/data" \
    --icon src/fileaxa_batch/data/icon.svg \
    src/fileaxa_batch/__main__.py
ok "Python bundle at $BUNDLE_DIR"

# ---- bundle Chromium -------------------------------------------------------

CHROMIUM_CACHE="${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.cache/ms-playwright}"
if [[ ! -d "$CHROMIUM_CACHE" ]]; then
    warn "Playwright Chromium not found at $CHROMIUM_CACHE"
    warn "    Run: .venv/bin/playwright install chromium"
    warn "    Then re-run bin/build to include the browser in the bundle."
    exit 1
fi

# Only copy the chromium directories (skip ffmpeg/firefox/webkit if present).
say "Copying Chromium from $CHROMIUM_CACHE"
mkdir -p "$BUNDLE_DIR/browsers"
shopt -s nullglob
for d in "$CHROMIUM_CACHE"/chromium-* "$CHROMIUM_CACHE"/chromium_headless_shell-*; do
    name=$(basename "$d")
    cp -a "$d" "$BUNDLE_DIR/browsers/$name"
done
shopt -u nullglob
ok "Chromium copied into $BUNDLE_DIR/browsers"

# ---- done ------------------------------------------------------------------

BUNDLE_SIZE=$(du -sh "$BUNDLE_DIR" 2>/dev/null | awk '{print $1}')
echo
ok "Bundle ready: $BUNDLE_DIR ($BUNDLE_SIZE)"
echo
echo "Launch the bundled binary from here:"
echo "    $BUNDLE_DIR/fileaxa-batch"
echo
echo "To distribute, package the entire directory:"
echo "    cd \"$(dirname "$BUNDLE_DIR")\" && tar -czf fileaxa-batch.tar.gz fileaxa-batch"
echo
echo "On the target machine, extract the tarball then run:"
echo "    ./fileaxa-batch/fileaxa-batch"
